# ============================================================================
# Frontend Environment Configuration
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` to git.
# ============================================================================

# ---------- Backend API URL ----------
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# AWS EC2 production (from 서버사용(재가공).pptx)
# NOTE: EC2 IP is not static — it changes on instance restart.
# Update this value each time the instance is restarted, or use a static Elastic IP.
# NEXT_PUBLIC_API_URL=http://15.164.48.153:8000

# ---------- Cesium Ion Access Token ----------
# Get your token from: https://cesium.com/ion/
NEXT_PUBLIC_CESIUM_TOKEN=your_cesium_ion_access_token

# ---------- V-World API Key (국토정보플랫폼) ----------
# Get your key from: https://www.vworld.kr/dev/v4api.do
VWORLD_API_KEY=your_vworld_api_key

# ---------- Google AI Studio (Nano Banana / Gemini 2.5 Flash Image) ----------
# 결과 페이지(/editor/result)의 "AI 렌더링" 버튼이 사용.
# 캡처된 배치도/조감도를 사실적인 건축 렌더링으로 변환.
# Get your key: https://aistudio.google.com/app/apikey
# 무료 tier 사용 가능 (rate limit 있음).
GOOGLE_AI_API_KEY=your_google_ai_studio_api_key

# (선택) 모델 ID 오버라이드. 기본값: gemini-2.5-flash-image-preview
# NANO_BANANA_MODEL=gemini-2.5-flash-image-preview
