# ============================================================================
# Frontend Environment Configuration
# Copy this file to `.env.local` and fill in real values.
# NEVER commit `.env.local` to git.
# ============================================================================

# ---------- Backend API URL ----------
# Local development
NEXT_PUBLIC_API_URL=http://localhost:8000
#
# AWS EC2 production (from 서버사용(재가공).pptx)
# NOTE: EC2 IP is not static — it changes on instance restart.
# Update this value each time the instance is restarted, or use a static Elastic IP.
# NEXT_PUBLIC_API_URL=http://15.164.48.153:8000

# ---------- Cesium Ion Access Token ----------
# Get your token from: https://cesium.com/ion/
NEXT_PUBLIC_CESIUM_TOKEN=your_cesium_ion_access_token

# ---------- V-World API Key (국토정보플랫폼) ----------
# Get your key from: https://www.vworld.kr/dev/v4api.do
VWORLD_API_KEY=your_vworld_api_key
