# ============================================================================
# Backend Environment Configuration
# Copy this file to `.env` and fill in real values.
# NEVER commit `.env` to git.
# ============================================================================

# ---------- Server ----------
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000

# ---------- Database (PostgreSQL) ----------
# Local development
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/building_db
#
# AWS RDS production (from 서버사용(재가공).pptx)
# Format: postgresql://<user>:<password>@<endpoint>:5432/<dbname>
DATABASE_URL=postgresql://your_username:your_password@your-rds-endpoint.rds.amazonaws.com:5432/your_database

# Set to "null" to disable connection pooling (useful for serverless)
# DATABASE_POOL=null

# Enable SQL echo for debugging
SQL_ECHO=false

# ---------- AI Server ----------
# Local development (team member's local AI server)
# AI_SERVER_URL=http://localhost:8001
#
# 학과 서버 (ceprj2) - from 서버사용(AI).pptx
# Note: ceprj2 is SSH-accessible. Team must expose AI inference as an HTTP endpoint.
# Confirm with team whether port 65006 (or another) runs the FastAPI/AI inference service.
AI_SERVER_URL=http://ceprj2.gachon.ac.kr:65006

# ---------- CORS ----------
# Comma-separated list of allowed frontend origins.
# Use "*" for open access (development only).
# Production example: https://your-frontend.com,http://15.164.48.153:3000
CORS_ORIGINS=*

# ---------- File Storage ----------
# Directory for uploaded DXF files and generated GLB models.
# Defaults are relative to backend/ working directory.
# UPLOAD_DIR=uploads
# MODELS_DIR=models

# ---------- Logging ----------
LOG_LEVEL=INFO
